  "runtimes": {
    "ollama": {
      "display_name": "Ollama",
      "install_command": "curl -fsSL https://ollama.com/install.sh | sh",
      "pull_command": "ollama pull {model}",
      "run_command": "ollama run {model}",
      "list_command": "ollama list",
      "health_check": "curl -f http://localhost:11434/api/tags"
    },
    "llamacpp": {
      "display_name": "llama.cpp",
      "install_command": "git clone https://github.com/ggerganov/llama.cpp && cd llama.cpp && make",
      "download_command": "wget -O {output} {url}",
      "run_command": "./main -m {model} -p {prompt}",
      "health_check": "test -f {model}"
    },
    "vllm_local": {
      "display_name": "Local vLLM",
      "install_command": "pip install vllm",
      "run_command": "vllm serve {model}",
      "health_check": "curl -f http://localhost:8000/v1/models"
    }
  },

