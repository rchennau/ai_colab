# ai-colab Docker Ignore File

# Git
.git
.gitignore
.gitattributes

# Qwen/AI Colab state
.qwen/
.ai-colab-state.json
.ai-colab-prefs
.ai-colab-backup*/

# Configuration (mounted as volumes)
config/backups/
config/profiles/

# Logs
logs/
*.log

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/

# Node
node_modules/
npm-debug.log
yarn-error.log

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.tmp
*.temp

# Test
tests/
*.test.js
*.spec.js

# Documentation
docs/
*.md
!README.md

# Scripts not needed in container
scripts/install-wizard.sh
scripts/migrate-*.sh

# Docker build artifacts
docker/build/

# Backup files
*.bak
*.backup

# Environment files (use Docker env instead)
.env
.env.local
.env.*.local

# Runpod/NVIDIA specific
runpod/
.nvidia/

# Local development
*.local
local/
dev/
