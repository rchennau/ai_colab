# ai-colab Environment Configuration
# Copy this file to .env and fill in your values
# Usage: cp .env.example .env && docker compose up -d

# ============================================================
# General Settings
# ============================================================
TZ=UTC
COMPUTE_BACKEND=local
CONDUCTOR_INTERVAL=60

# ============================================================
# MQTT Security
# ============================================================
# Auto-generated on first run if not provided
MQTT_USERNAME=ai-colab-admin
MQTT_PASSWORD=change-me-on-first-deployment

# ============================================================
# LLM API Keys (uncomment and fill in as needed)
# ============================================================
# GEMINI_API_KEY=your-gemini-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
# QWEN_API_KEY=your-qwen-api-key
# NVIDIA_API_KEY=your-nvidia-api-key
# RUNPOD_API_KEY=your-runpod-api-key
